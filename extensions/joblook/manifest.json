{
  "manifest_version": 3,
  "name": "JobLook",
  "version": "0.1.0",
  "description": "Auto-fill job applications on Greenhouse, Lever, and Ashby. You click submit.",
  "minimum_chrome_version": "116",
  "action": {
    "default_title": "JobLook — autofill job applications",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://boards.greenhouse.io/*",
    "https://*.greenhouse.io/*",
    "https://jobs.lever.co/*",
    "https://jobs.ashbyhq.com/*",
    "https://api.joblook.ai/*",
    "http://localhost:8000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://boards.greenhouse.io/*",
        "https://*.greenhouse.io/*"
      ],
      "js": ["content/loader.js"],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": [
      "https://joblook.ai/*",
      "http://localhost:8000/*"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["content/*", "popup/*"],
      "matches": [
        "https://boards.greenhouse.io/*",
        "https://*.greenhouse.io/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
